<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="Feduniak-8" author="Yurii Feduniak">

        <createTable tableName="participation">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey columnNames="user_id, event_id" tableName="participation"/>

        <addForeignKeyConstraint baseTableName="participation" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_participation_user"/>

        <addForeignKeyConstraint baseTableName="participation" baseColumnNames="event_id"
                                 referencedTableName="event" referencedColumnNames="id"
                                 constraintName="fk_participation_event"/>
    </changeSet>

</databaseChangeLog>