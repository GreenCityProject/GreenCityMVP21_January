<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="Feduniak-7" author="Yurii Feduniak">

        <createTable tableName="event_likes">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="is_liked" type="BOOLEAN"/>
            <column name="is_disliked" type="BOOLEAN"/>
        </createTable>

        <addPrimaryKey columnNames="user_id, event_id" tableName="event_likes"/>

        <addForeignKeyConstraint baseTableName="event_likes" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_event_likes_user"/>

        <addForeignKeyConstraint baseTableName="event_likes" baseColumnNames="event_id"
                                 referencedTableName="event" referencedColumnNames="id"
                                 constraintName="fk_event_likes_event"/>
    </changeSet>

</databaseChangeLog>