<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="Bulhakova-3" author="Oleksandra Bulhakova">
        <createTable tableName="event_image">
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="image_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="event_image" columnNames="event_id, image_id" constraintName="pk_event_image"/>
        <addForeignKeyConstraint baseTableName="event_image" baseColumnNames="event_id"
                                 referencedTableName="event" referencedColumnNames="id"
                                 constraintName="fk_event_image_event"/>
        <addForeignKeyConstraint baseTableName="event_image" baseColumnNames="image_id"
                                 referencedTableName="image" referencedColumnNames="id"
                                 constraintName="fk_event_image_image"/>

    </changeSet>

</databaseChangeLog>