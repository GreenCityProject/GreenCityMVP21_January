<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="Feduniak-2" author="Yurii Feduniak">
        <createTable tableName="event_comment_likes_key">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="event_comment_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="user_id, event_comment_id" tableName="event_comment_likes_key"/>


        <addForeignKeyConstraint baseTableName="event_comment_likes_key" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_event_comment_likes_key_user"/>

        <addForeignKeyConstraint baseTableName="event_comment_likes_key" baseColumnNames="event_comment_id"
                                 referencedTableName="event_comment" referencedColumnNames="id"
                                 constraintName="fk_event_comment_likes_key_event_comment"/>
    </changeSet>

</databaseChangeLog>