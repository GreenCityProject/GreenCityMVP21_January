<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="Bulhakova-4" author="Oleksandra Bulhakova">
        <addColumn tableName="event">
            <column name="main_image_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="event" baseColumnNames="main_image_id"
                                 referencedTableName="image" referencedColumnNames="id"
                                 constraintName="fk_event_main_image"/>
    </changeSet>

</databaseChangeLog>